# Copy this file to ".env" and adjust the values. Do NOT commit .env to the repository.
#   cp .env.example .env

# Public domain used to reach Grafana (must match nginx.conf).
GRAFANA_DOMAIN=grafana.tu-dominio.com

# Initial Grafana admin credentials.
# Use a strong password and change it after the first login.
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=CHANGE_ADMIN_STRONG

# ClickHouse user password (consumed by provisioning/datasources/clickhouse.yaml).
CLICKHOUSE_PASSWORD=CHANGE_CLICKHOUSE

# --- SMTP (optional) — only if you plan to send email alerts ---
# Also uncomment the GF_SMTP_* lines in docker-compose.yaml.
#GF_SMTP_HOST=smtp.your-provider.com:587
#GF_SMTP_USER=smtp_user
#GF_SMTP_PASSWORD=smtp_secret
#GF_SMTP_FROM_ADDRESS=alerts@your-domain.com
#GF_SMTP_FROM_NAME=Grafana
